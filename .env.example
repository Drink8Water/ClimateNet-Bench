# PostgreSQL connection string used by src/load_to_db.py and the FastAPI backend.
# Replace username, password, host, port, and database name with your local setup.
DATABASE_URL=postgresql+psycopg2://climate_user:climate_password@localhost:5432/climate_ml

# Streamlit uses the API when available, then falls back to local CSV/PNG files.
API_BASE_URL=http://127.0.0.1:8000

# Optional: database loader source directory. Defaults to outputs/experiments/latest.
EXPERIMENT_OUTPUT_DIR=outputs/experiments/latest
